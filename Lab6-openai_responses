import streamlit as st
from openai import OpenAI

# openai client
client = OpenAI(api_key=st.secrets["OPENAI_API_KEY"])

# Show title and description.
st.title("Lab 6 with OpenAI Responses API")
st.write(" ")
st.title("Questions Chatbot")
st.write("Ask the bot any questions you have in mind! " \
"This bot uses a multi-turn agent that uses a built-in tool and maintain conversation state without manually managing a message history list.")

# user input
question = st.text_input("Ask any question: ")

# bot call
if question:
    response = client.responses.creat(
        model = "gpt-4.1-mini",
        instructions = "You are a helpful research assistant.",
        input = question
    )

    st.write(response.output_text)